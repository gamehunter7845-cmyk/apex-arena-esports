<%- include('../partials/header') %>

<div class="page-header">
  <h2>Create Tournament</h2>
  <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Back</a>
</div>

<div class="form-card">
  <form action="/admin/tournament/create" method="POST">

    <div class="form-group">
      <label>Tournament Name</label>
      <input
        type="text"
        name="name"
        placeholder="e.g. Friday Clash #3"
        required
      />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Date</label>
        <input type="date" name="date" required />
      </div>
      <div class="form-group">
        <label>Time</label>
        <input type="time" name="time" required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Room ID</label>
        <input
          type="text"
          name="roomId"
          placeholder="e.g. 123456"
          required
        />
      </div>
      <div class="form-group">
        <label>Room Password</label>
        <input
          type="text"
          name="roomPassword"
          placeholder="e.g. pass99"
          required
        />
      </div>
    </div>

    <div class="form-group">
      <label>WhatsApp Channel Link</label>
      <input
        type="url"
        name="whatsappLink"
        placeholder="https://chat.whatsapp.com/xxxx"
        required
      />
    </div>

    <div class="form-group">
      <label>Maximum Teams</label>
      <input
        type="number"
        name="maxTeams"
        placeholder="e.g. 12"
        min="1"
        max="100"
        required
      />
    </div>

    <button type="submit" class="btn btn-primary btn-full">
      Create Tournament
    </button>

  </form>
</div>

<%- include('../partials/footer') %>